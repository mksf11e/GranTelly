# Public demo example only. Do not put real credentials in this file.

GIMY_DEVICE_WS_URL=ws://localhost:8765/device
GIMY_DEVICE_ID=esp32-public-demo

# Private deployments can use any OpenAI-compatible multimodal endpoint.
GIMY_LLM_BASE_URL=https://your-openai-compatible-multimodal-endpoint.example/v1
GIMY_LLM_API_KEY=replace_with_your_own_key

# Optional family-side channel for private deployments.
GIMY_TELEGRAM_BOT_TOKEN=replace_with_your_own_bot_token

